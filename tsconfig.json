{
    "compilerOptions": {
        "module": "Node16",
        "target": "ES2021",
        "outDir": "out",
        "rootDir": "src",
        "lib": [
            "ES2021"
        ],
        "types": [
            "node"
        ],
        "sourceMap": true,
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "moduleResolution": "Node16"
    },
    "include": [
        "src"
    ],
    "exclude": [
        "node_modules",
        "out"
    ]
}